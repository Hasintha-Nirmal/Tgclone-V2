# Telegram API Credentials (OPTIONAL - can login via web interface)
# Get from https://my.telegram.org
# Leave empty to login accounts only via web dashboard
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=

# Additional accounts (optional)
TELEGRAM_API_ID_2=
TELEGRAM_API_HASH_2=
TELEGRAM_PHONE_2=

# Database
DATABASE_URL=sqlite:///./data/app.db
# DATABASE_URL=postgresql://user:pass@localhost/dbname

# Redis (optional, for queue system)
REDIS_URL=redis://localhost:6379/0
USE_REDIS=false

# Web Dashboard - CHANGE THESE IMMEDIATELY!
WEB_HOST=0.0.0.0
WEB_PORT=8000

# CRITICAL: Generate strong credentials before deployment!
# Generate password: python -c "import secrets; print(secrets.token_urlsafe(16))"
# Generate secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE-THIS-TO-STRONG-PASSWORD-MIN-12-CHARS
SECRET_KEY=CHANGE-THIS-TO-RANDOM-SECRET-KEY-MIN-16-CHARS

# CORS - Allowed origins (comma-separated)
# For production, set to your actual domain(s)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Storage Settings
AUTO_DELETE_FILES=true
MAX_DOWNLOAD_SIZE_MB=2000
TEMP_DIR=./downloads

# Worker Settings
WORKER_THREADS=3
SYNC_INTERVAL_SECONDS=30
MAX_RETRIES=3
FLOOD_WAIT_MULTIPLIER=1.5

# Rate Limiting (Account Protection)
# Adjust these based on your Telegram account limits
DELAY_BETWEEN_MESSAGES=1.0
DELAY_BETWEEN_MEDIA=2.0
BREAK_EVERY_N_MESSAGES=10
BREAK_DURATION=15.0
MAX_MESSAGES_PER_HOUR=100

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
