# Telegram API Credentials (OPTIONAL - can login via web interface)
# Get from https://my.telegram.org
# Leave empty to login accounts only via web dashboard
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=

# Additional accounts (optional)
TELEGRAM_API_ID_2=
TELEGRAM_API_HASH_2=
TELEGRAM_PHONE_2=

# Database
DATABASE_URL=sqlite:///./data/app.db
# DATABASE_URL=postgresql://user:pass@localhost/dbname

# Redis (optional, for queue system)
REDIS_URL=redis://localhost:6379/0
USE_REDIS=false

# Web Dashboard
WEB_HOST=0.0.0.0
WEB_PORT=8000
SECRET_KEY=change-this-to-random-secret-key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Storage Settings
AUTO_DELETE_FILES=true
MAX_DOWNLOAD_SIZE_MB=2000
TEMP_DIR=./downloads

# Worker Settings
WORKER_THREADS=3
SYNC_INTERVAL_SECONDS=30
MAX_RETRIES=3
FLOOD_WAIT_MULTIPLIER=1.5

# Rate Limiting (Account Protection)
# Based on Telegram best practices to avoid bans and flood limits
# Research sources: Telegram API guidelines, community best practices (2024-2026)

# Delay between text messages (seconds)
# Recommended: 2-5 seconds for safe operation
# Lower values (0.5-1.5) = faster but higher ban risk
# Higher values (5-10) = slower but safer for new accounts
DELAY_BETWEEN_MESSAGES=3.0

# Delay between media messages (seconds)
# Media uploads are more resource-intensive and monitored closely
# Recommended: 5-15 seconds to avoid detection
DELAY_BETWEEN_MEDIA=8.0

# Take a break every N messages
# Recommended: 20-40 messages to simulate human behavior
# Lower values = more breaks, safer but slower
# Higher values = fewer breaks, faster but riskier
BREAK_EVERY_N_MESSAGES=30

# Break duration (seconds)
# Recommended: 120-300 seconds (2-5 minutes)
# Simulates natural pauses in human messaging patterns
BREAK_DURATION=180.0

# Maximum messages per hour (safety limit)
# Recommended for aged accounts: 100-150/hour
# Recommended for new accounts: 40-60/hour
# This prevents account flagging and respects Telegram's infrastructure
MAX_MESSAGES_PER_HOUR=120

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
